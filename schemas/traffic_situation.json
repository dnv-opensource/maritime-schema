    "AisShipType": {
      "description": "AIS Ship Type (not including cargo type).\nSource: https://www.itu.int/dms_pubrec/itu-r/rec/m/R-REC-M.1371-5-201402-I!!PDF-E.pdf#page=116.",
      "enum": [
        "Not available",
        "Wing in ground",
        "Fishing",
        "Towing",
        "Towing large",
        "Dredging or underwater operations",
        "Diving operations",
        "Military operations",
        "Sailing",
        "Pleasure craft",
        "High speed craft",
