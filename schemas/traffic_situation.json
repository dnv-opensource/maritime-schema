    "DataPoint": {
      "additionalProperties": true,
      "properties": {
        "value": {
          "description": "the value of the data at the current waypoint",
          "examples": [
            12.3
          ],
          "title": "Value",
          "type": "number"
        },
        "interpStart": {
          "description": "distance (in nautical miles) before the start of the next leg, to start interpolating to the next leg's value",
          "examples": [
            10
          ],
          "title": "Interp Start",
          "type": "number"
        },
        "interpEnd": {
          "description": "distance (in nautical miles) after the start of the next leg, to finish interpolating to the next leg's value",
          "examples": [
            10
          ],
          "title": "Interp End",
          "type": "number"
        },
        "interpMethod": {
          "anyOf": [
            {
              "$ref": "#/$defs/InterpolationMethod"
            },
            {
              "type": "string"
            }
          ],
          "description": "Method used for interpolation",
          "title": "Interp Method"
        }
      },
      "title": "DataPoint",
      "type": "object"
    },
    "Dimensions": {
      "additionalProperties": true,
      "description": "    Key Ship Dimensions.\n\n              Bow\n              (a)\n               ^\n              /\u2506                 / \u2506                 /  \u2506                 /   \u2506                 /    \u2506                 \u2502     \u2506     \u2502\n         \u2502     \u2506     \u2502\n         \u2502     \u2506     \u2502\n         \u2502     \u2506     \u2502\nPort (c) \u2502\u254c\u254c\u254c\u254c\u254c\u2666\u254c\u254c\u254c\u254c\u254c\u2502 (d) Starboard\n         \u2502     \u2506     \u2502\n         \u2502     \u2506     \u2502\n         \u2502     \u2506     \u2502\n         \u2514\u2500\u2500\u2500\u2500\u2500\u2534\u2500\u2500\u2500\u2500\u2500\u2518\n              (b)\n             Stern\n\n          \u2666 = CCRP",
      "properties": {
        "length": {
          "description": "Length of the ship in meters. If a and b are provided, this shall be equal to A + B",
          "examples": [
            130.0
          ],
          "exclusiveMinimum": 0,
          "title": "Length",
          "type": "number"
        },
        "width": {
          "description": "Width of the ship in meters. If c and d are provided, this shall be equal to C + D",
          "examples": [
            30.0
          ],
          "exclusiveMinimum": 0,
          "title": "Width",
          "type": "number"
        },
        "height": {
          "description": "Height of the ship in meters",
          "examples": [
            15.0
          ],
          "exclusiveMinimum": 0,
          "title": "Height",
          "type": "number"
        },
        "draught": {
          "description": "Draught of the ship in meters",
          "examples": [
            15.0
          ],
          "exclusiveMinimum": 0,
          "title": "Draught",
          "type": "number"
        },
        "a": {
          "description": "Distance in meters from CCRP to Bow",
          "examples": [
            80
          ],
          "exclusiveMinimum": 0,
          "title": "A",
          "type": "number"
        },
        "b": {
          "description": "Distance in meters from CCRP to Stern",
          "examples": [
            20
          ],
          "exclusiveMinimum": 0,
          "title": "B",
          "type": "number"
        },
        "c": {
          "description": "Distance in meters from CCRP to Port",
          "examples": [
            20
          ],
          "exclusiveMinimum": 0,
          "title": "C",
          "type": "number"
        },
        "d": {
          "description": "Distance in meters from CCRP to Starboard",
          "examples": [
            20
          ],
          "exclusiveMinimum": 0,
          "title": "D",
          "type": "number"
        }
      },
      "title": "Dimensions",
      "type": "object"
    },
    "Environment": {
      "additionalProperties": true,
      "properties": {
        "windSpeed": {
          "description": "The wind speed in m/s",
          "examples": [
            10.0
          ],
          "minimum": 0,
          "title": "Wind Speed",
          "type": "number"
        },
        "windDirection": {
          "description": "The direction the wind is coming from, in degrees.",
          "examples": [
            180.0
          ],
          "maximum": 360,
          "minimum": 0,
          "title": "Wind Direction",
          "type": "number"
        },
        "currentSpeed": {
          "description": "The water current speed in m/s",
          "examples": [
            1.0
          ],
          "minimum": 0,
          "title": "Current Speed",
          "type": "number"
        },
        "currentDirection": {
          "description": "The direction the water current is flowing towards, in degrees.",
          "examples": [
            90.0
          ],
          "maximum": 360,
          "minimum": 0,
          "title": "Current Direction",
          "type": "number"
        },
        "waveSpectrum": {
          "$ref": "#/$defs/WaveSpectra",
          "description": "The wave spectrum",
          "examples": [
            "JONSWAP"
          ],
          "title": "Wave Spectrum"
        },
        "significantWaveHeight": {
          "description": "The significant wave height in meters",
          "examples": [
            3.0
          ],
          "title": "Significant Wave Height",
          "type": "number"
        },
        "wavePeriod": {
          "description": "The peak wave period in seconds",
          "examples": [
            12.0
          ],
          "title": "Wave Period",
          "type": "number"
        },
        "waveDirection": {
          "description": "The direction the waves are coming from, in degrees (meteorological convention)",
          "examples": [
            270.0
          ],
          "maximum": 360,
          "minimum": 0,
          "title": "Wave Direction",
          "type": "number"
        },
        "visibility": {
          "description": "The visibility in nautical miles",
          "examples": [
            5.0
          ],
          "title": "Visibility",
          "type": "number"
        },
        "conditions": {
          "$ref": "#/$defs/WeatherCondition",
          "description": "The overall weather conditions",
          "examples": [
            "Clear"
          ],
          "title": "Conditions"
        }
      },
      "title": "Environment",
      "type": "object"
    },
    "GeoPosition": {
      "additionalProperties": true,
      "properties": {
        "lon": {
          "description": "WGS-84 Longitude",
          "examples": [
            10.3432
          ],
          "maximum": 180,
          "minimum": -180,
          "title": "Lon",
          "type": "number"
        },
        "lat": {
          "description": "WGS-84 Latitude",
          "examples": [
            57.2343
          ],
          "maximum": 90,
          "minimum": -90,
          "title": "Lat",
          "type": "number"
        }
      },
      "required": [
        "lon",
        "lat"
      ],
      "title": "GeoPosition",
      "type": "object"
    },
    "InterpolationMethod": {
      "enum": [
        "linear",
        "cosine",
        "smoothstep",
        "accelerate",
        "decelerate",
        "ordinal"
      ],
      "title": "InterpolationMethod",
      "type": "string"
    },
    "Leg": {
      "additionalProperties": true,
      "properties": {
        "starboardXtd": {
          "description": "Starboard cross-track distance (XTD) in nautical miles as defined in RTZ.",
          "title": "Starboard Xtd",
          "type": "number"
        },
        "portsideXtd": {
          "description": "Portside cross-track distance (XTD) in nautical miles as defined in RTZ.",
          "title": "Portside Xtd",
          "type": "number"
        },
        "sog": {
          "description": "Planned speed over ground in knots for this leg. If provided, `leg.data.sog` shall take priority over `leg.sog`.",
          "title": "Sog",
          "type": "number"
        },
        "data": {
          "$ref": "#/$defs/RouteData",
          "description": "The `data` field can be used to store data that is numerical and continuous. One such example is the vessel's speed over ground (SOG). Every `data` object can have the following 4 attributes:\n\n`value`: This is the value of the data over the current leg.\n\n`interpStart`: This is the distance (in nautical miles) before the leg change, where the value will start changing (via interpolation) to the new value in the next leg.\n\n`interpEnd`: This is the distance (in nautical miles) after the leg change, where the value will finish changing (via interpolation) to the new value in the next leg.\n\n`interpMethod`: This sets the interpolation (linear, cosine, smoothstep, etc.) that will be used to perform the interpolation.",
          "title": "Data"
        }
      },
      "title": "Leg",
      "type": "object"
    },
    "OwnShip": {
      "additionalProperties": true,
      "properties": {
        "waypoints": {
          "description": "An array of `Waypoint` objects. Each waypoint object must have a `position` property. If no turn radius is provided, it will be assumed to be `0`. Additional data can be added to each waypoint leg.",
          "items": {
            "$ref": "#/$defs/Waypoint"
          },
          "minItems": 1,
          "title": "Waypoints",
          "type": "array"
        },
        "static": {
          "$ref": "#/$defs/ShipStatic",
          "description": "Static ship information which does not change during a scenario.",
          "title": "Static"
        },
        "initial": {
          "$ref": "#/$defs/ShipState",
          "description": "Initial pose of the ship at the start of the scenario. If not provided, it will be initialized at the position and course of the first waypoint.",
          "title": "Initial"
        }
      },
      "required": [
        "waypoints",
        "static"
      ],
      "title": "OwnShip",
      "type": "object"
    },
    "PathType": {
      "enum": [
        "rtz",
        "bezier",
        "linear"
      ],
      "title": "PathType",
      "type": "string"
    },
    "RouteData": {
      "additionalProperties": {
        "$ref": "#/$defs/DataPoint"
      },
      "description": "A dictionary of named data channels for a leg.\n\nCommon keys:\n    - ``sog``: Speed over ground in knots.\n    - ``heading``: Ship heading in degrees.\n\nCustom string keys are also supported.",
      "title": "RouteData",
      "type": "object"
    },
    "ShipState": {
      "additionalProperties": true,
      "description": "The current state of a ship.",
      "properties": {
        "position": {
          "$ref": "#/$defs/GeoPosition",
          "description": "Longitude and latitude of the ship.",
          "examples": [
            {
              "lat": 57.2343,
              "lon": 10.3432
            }
          ],
          "title": "Position"
        },
        "sog": {
          "description": "Ship speed over ground (SOG) in knots",
          "examples": [
            10.0
          ],
          "minimum": 0,
          "title": "Sog",
          "type": "number"
        },
        "cog": {
          "description": "Ship course over ground (COG) in degrees",
          "examples": [
            45.0
          ],
          "maximum": 360,
          "minimum": 0,
          "title": "Cog",
          "type": "number"
        },
        "heading": {
          "description": "Ship heading in degrees",
          "examples": [
            45.2
          ],
          "maximum": 360,
          "minimum": 0,
          "title": "Heading",
          "type": "number"
        },
        "navStatus": {
          "anyOf": [
            {
              "$ref": "#/$defs/AisNavStatus"
            },
            {
              "$ref": "#/$defs/AisNavStatusInt"
            }
          ],
          "description": "AIS Navigational Status",
          "title": "Nav Status"
        }
      },
      "title": "ShipState",
      "type": "object"
    },
    "ShipStatic": {
      "additionalProperties": true,
      "description": "Static ship data that will not change during the scenario.",
      "properties": {
        "id": {
          "description": "Ship Identifier",
          "examples": [
            1
          ],
          "maximum": 4294967296,
          "minimum": 0,
          "title": "Id",
          "type": "integer"
        },
        "mmsi": {
          "description": "Maritime Mobile Service Identity (MMSI)",
          "examples": [
            123456789
          ],
          "maximum": 999999999,
          "minimum": 100000000,
          "title": "Mmsi",
          "type": "integer"
        },
        "imo": {
          "description": "IMO Number",
          "examples": [
            1234567
          ],
          "maximum": 9999999,
          "minimum": 1000000,
          "title": "Imo",
          "type": "integer"
        },
        "name": {
          "description": "Ship name",
          "examples": [
            "RMS Titanic"
          ],
          "title": "Name",
          "type": "string"
        },
        "dimensions": {
          "$ref": "#/$defs/Dimensions",
          "description": "Key ship dimensions"
        },
        "shipType": {
          "anyOf": [
            {
              "$ref": "#/$defs/AisShipType"
            },
            {
              "$ref": "#/$defs/AisShipAndCargoType"
            },
            {
              "$ref": "#/$defs/AisShipAndCargoTypeInt"
            }
          ],
          "description": "General ship type, based on AIS",
          "title": "Ship Type"
        },
        "stationType": {
          "anyOf": [
            {
              "$ref": "#/$defs/AisStationType"
            },
            {
              "$ref": "#/$defs/AisStationTypeInt"
            }
          ],
          "description": "AIS station type",
          "title": "Station Type"
        },
        "positionFixingDevice": {
          "anyOf": [
            {
              "$ref": "#/$defs/AisPositionFixingDevice"
            },
            {
              "$ref": "#/$defs/AisPositionFixingDeviceInt"
            }
          ],
          "description": "AIS position fixing device",
          "title": "Position Fixing Device"
        },
        "pathType": {
          "anyOf": [
            {
              "$ref": "#/$defs/PathType",
              "description": "Specifies the control-point model (e.g., RTZ, Bezier) used to define the path for the ship to follow."
            },
            {
              "type": "null"
            }
          ],
          "default": "rtz",
          "title": "Path Type"
        },
        "initDelay": {
          "description": "Delay in seconds before the ship is initialized in the scenario",
          "examples": [
            15.0
          ],
          "minimum": 0,
          "title": "Init Delay",
          "type": "number"
        },
        "sogMin": {
          "description": "Minimum ship speed over ground in knots",
          "examples": [
            5.0
          ],
          "minimum": 0,
          "title": "Sog Min",
          "type": "number"
        },
        "sogMax": {
          "description": "Maximum ship speed over ground in knots",
          "examples": [
            15.0
          ],
          "minimum": 0,
          "title": "Sog Max",
          "type": "number"
        }
      },
      "required": [
        "id"
      ],
      "title": "ShipStatic",
      "type": "object"
    },
    "TargetShip": {
      "additionalProperties": true,
      "properties": {
        "waypoints": {
          "description": "An array of `Waypoint` objects. Each waypoint object must have a `position` property. If no turn radius is provided, it will be assumed to be `0`. Additional data can be added to each waypoint leg.",
          "items": {
            "$ref": "#/$defs/Waypoint"
          },
          "minItems": 1,
          "title": "Waypoints",
          "type": "array"
        },
        "static": {
          "$ref": "#/$defs/ShipStatic",
          "description": "Static ship information which does not change during a scenario.",
          "title": "Static"
        },
        "initial": {
          "$ref": "#/$defs/ShipState",
          "description": "Initial pose of the ship at the start of the scenario. If not provided, it will be initialized at the position and course of the first waypoint.",
          "title": "Initial"
        }
      },
      "required": [
        "waypoints",
        "static"
      ],
      "title": "TargetShip",
      "type": "object"
    },
    "WaveSpectra": {
      "enum": [
        "JONSWAP",
        "Pierson-Moskowitz",
        "Bretschneider"
      ],
      "title": "WaveSpectra",
      "type": "string"
    },
    "Waypoint": {
      "additionalProperties": true,
      "properties": {
        "position": {
          "$ref": "#/$defs/GeoPosition",
          "description": "A geographical coordinate.",
          "examples": [
            {
              "lat": 51.2123,
              "lon": 11.2313
            }
          ],
          "title": "Position"
        },
        "turnRadius": {
          "description": "Orthodrome turn radius in nautical miles as defined in RTZ.",
          "examples": [
            0.5
