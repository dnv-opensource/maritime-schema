  "$defs": {
    "AisNavStatus": {
      "description": "AIS Navigational Status.\nSource: https://www.itu.int/dms_pubrec/itu-r/rec/m/R-REC-M.1371-5-201402-I!!PDF-E.pdf#page=113.",
      "enum": [
        "Under way using engine",
        "At anchor",
        "Not under command",
        "Restricted maneuverability",
        "Constrained by her draught",
        "Moored",
        "Aground",
        "Engaged in fishing",
        "Under way sailing",
        "Reserved for future amendment DG, HS, MP, C, HSC",
        "Reserved for future amendment DG, HS, MP, A, WIG",
        "Power-driven vessel towing astern",
        "Power-driven vessel pushing ahead or towing alongside",
        "Reserved for future use",
        "AIS-SART (active)",
        "Undefined (default)"
      ],
      "title": "AisNavStatus",
      "type": "string"
    },
    "AisNavStatusInt": {
      "description": "AIS Navigational Status in Integer form.\nSource: https://www.itu.int/dms_pubrec/itu-r/rec/m/R-REC-M.1371-5-201402-I!!PDF-E.pdf#page=113.",
